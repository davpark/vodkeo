generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  did       String    @unique
  handle    String
  birthday  DateTime
  createdAt DateTime  @default(now())
  posts     Post[]    @relation("UserPosts")
  comments  Comment[] @relation("UserComments")
}

model Post {
  id           Int          @id @default(autoincrement())
  title        String
  content      String
  published    Boolean      @default(false)
  status       String       @default("approved")
  tags         String[]     @default([])
  authorDid    String
  authorHandle String?
  createdAt    DateTime     @default(now())
  author       UserProfile? @relation("UserPosts", fields: [authorDid], references: [did])
  comments     Comment[]
  views        Int          @default(0)
  score        Float        @default(0)
}

model Comment {
  id        Int         @id @default(autoincrement())
  content   String
  createdAt DateTime    @default(now())
  authorDid String
  author    UserProfile @relation("UserComments", fields: [authorDid], references: [did])
  post      Post        @relation(fields: [postId], references: [id])
  postId    Int
  parentId  Int?
  parent    Comment?    @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[]   @relation("CommentReplies")
}
